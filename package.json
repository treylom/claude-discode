{
  "name": "@treylom/claude-discode",
  "version": "1.0.0",
  "type": "module",
  "description": "KM ingestion + 4-Tier vault search (GraphRAG → Obsidian CLI → vault-search MCP → ripgrep). Multi-harness: Claude Code / Hermes / Gemini / OpenCode.",
  "keywords": [
    "claude-code",
    "hermes-agent",
    "gemini-cli",
    "agentskills",
    "knowledge-manager",
    "vault-search",
    "graphrag",
    "obsidian"
  ],
  "homepage": "https://github.com/treylom/claude-discode#readme",
  "bugs": "https://github.com/treylom/claude-discode/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/treylom/claude-discode.git"
  },
  "license": "MIT",
  "author": "tofukyung (김재경)",
  "files": [
    "contracts/",
    "scripts/",
    "skills/",
    "commands/",
    "templates/",
    "configs/",
    "hooks/",
    "hermes-plugin/",
    ".claude-plugin/",
    "gemini-extension.json",
    "GEMINI.md",
    "AGENTS.md",
    "README.md",
    "README.en.md",
    "LICENSE",
    "install.sh"
  ],
  "bin": {
    "claude-discode-km-version": "scripts/km-version.sh"
  },
  "scripts": {
    "validate": "bash scripts/validate-agents.sh",
    "index": "node scripts/generate-agents-index.mjs --apply",
    "index:check": "node scripts/check-agents-index.mjs",
    "test:agents": "bash tests/agents/test-schema-validation.sh && bash tests/agents/test-all-yamls.sh && bash tests/agents/test-index-roundtrip.sh"
  },
  "devDependencies": {
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^2.1.1",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
